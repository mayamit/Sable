---
import Card from './Card.astro';
import { accent as accentMap, type Accent } from '../lib/accents';

interface Props {
  name: string;
  tagline: string;
  body: string;
  example: string;
  accent?: Accent;
}
const { name, tagline, body, example, accent = 'violet' } = Astro.props;
const a = accentMap[accent];
---

<Card as="article" hover class="group flex flex-col p-7">
  <div class="flex items-center gap-3">
    <span class={`flex h-11 w-11 items-center justify-center rounded-[10px] ${a.softBg}`}>
      <span class={`h-3 w-3 rounded-full ${a.bg}`}></span>
    </span>
    <div>
      <h3 class="text-xl font-semibold text-ink">{name}</h3>
      <p class={`text-sm font-medium ${a.text}`}>{tagline}</p>
    </div>
  </div>
  <p class="mt-5 text-[15px] leading-relaxed text-ink-2">{body}</p>
  <div class="mt-6 rounded-[var(--radius-btn)] border border-border bg-bg px-4 py-3">
    <p class="text-xs font-medium uppercase tracking-wider text-muted">Try asking</p>
    <p class="mt-1 text-[15px] font-medium text-ink">{example}</p>
  </div>
</Card>
