---
import SectionShell from '../SectionShell.astro';
import SectionHeading from '../SectionHeading.astro';
import StepDiagram from '../StepDiagram.astro';
import Button from '../Button.astro';
import { howItWorks } from '../../data/home';
---

<SectionShell class="bg-surface border-y border-border">
  <SectionHeading
    eyebrow="How it works"
    title={howItWorks.headline}
    subhead={howItWorks.subhead}
    center
  />

  <div class="mt-14">
    <StepDiagram steps={howItWorks.steps} />
  </div>

  <div class="mt-10 text-center">
    <Button href={howItWorks.cta.href} variant="secondary">{howItWorks.cta.label}</Button>
  </div>
</SectionShell>
