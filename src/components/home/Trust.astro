---
import SectionShell from '../SectionShell.astro';
import SectionHeading from '../SectionHeading.astro';
import TrustPoints from '../TrustPoints.astro';
import NavigatorApproval from '../NavigatorApproval.astro';
import Button from '../Button.astro';
import { trust } from '../../data/home';
---

<SectionShell>
  <SectionHeading eyebrow="Trust by design" title={trust.headline} subhead={trust.subhead} center />

  <div class="mt-12 grid items-start gap-10 lg:grid-cols-[0.9fr_1.1fr]">
    <TrustPoints points={trust.points} cols={2} class="lg:!grid-cols-1" />
    <NavigatorApproval />
  </div>

  <div class="mt-10 text-center">
    <Button href={trust.cta.href} variant="secondary">{trust.cta.label}</Button>
  </div>
</SectionShell>
