---
import SectionShell from '../SectionShell.astro';
import SectionHeading from '../SectionHeading.astro';
import PricingTable from '../PricingTable.astro';
import { pricing } from '../../data/home';
---

<SectionShell>
  <SectionHeading eyebrow="Pricing" title={pricing.headline} subhead={pricing.subhead} center />

  <div class="mt-12">
    <PricingTable
      price={pricing.price}
      cadence={pricing.cadence}
      includes={pricing.includes}
      cta={pricing.cta}
      note={pricing.note}
    />
  </div>
</SectionShell>
