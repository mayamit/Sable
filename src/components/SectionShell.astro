---
interface Props {
  id?: string;
  /** Tighter vertical rhythm when true. */
  tight?: boolean;
  /** Optional class hook for background variants. */
  class?: string;
}
const { id, tight = false, class: klass = '' } = Astro.props;
const pad = tight ? 'py-14 sm:py-16' : 'py-20 sm:py-28';
---

<section id={id} class={`${pad} ${klass}`}>
  <div class="mx-auto w-full max-w-6xl px-5 sm:px-8">
    <slot />
  </div>
</section>
