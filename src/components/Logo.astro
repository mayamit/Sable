---
// Placeholder Sable wordmark (indigo) until final brand assets exist.
interface Props {
  class?: string;
}
const { class: klass = '' } = Astro.props;
---

<span class={`inline-flex items-center gap-2 ${klass}`}>
  <svg width="26" height="26" viewBox="0 0 26 26" fill="none" aria-hidden="true">
    <rect width="26" height="26" rx="7" fill="url(#sable-grad)" />
    <path
      d="M16.5 9.2c-.7-.9-1.9-1.5-3.3-1.5-2.1 0-3.6 1.2-3.6 2.9 0 4 7.4 2.3 7.4 6.5 0 1.9-1.7 3.2-4.1 3.2-1.8 0-3.3-.7-4.1-1.9"
      stroke="#fff"
      stroke-width="1.7"
      stroke-linecap="round"
      fill="none"
    />
    <defs>
      <linearGradient id="sable-grad" x1="0" y1="0" x2="26" y2="26" gradientUnits="userSpaceOnUse">
        <stop stop-color="#6A5CF6" />
        <stop offset="1" stop-color="#8B7CF8" />
      </linearGradient>
    </defs>
  </svg>
  <span class="text-[19px] font-bold tracking-[-0.02em] text-ink">Sable</span>
</span>
