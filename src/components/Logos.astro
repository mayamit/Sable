---
// Row of pill "logos" (connectors / integrations). Uses a gradient dot as a
// placeholder mark until real brand logos exist — never fake third-party logos.
interface Props {
  items: string[];
  class?: string;
}
const { items, class: klass = '' } = Astro.props;
---

<div class={`grid grid-cols-2 gap-3 sm:grid-cols-3 ${klass}`}>
  {
    items.map((item) => (
      <div class="flex items-center gap-2.5 rounded-[var(--radius-btn)] border border-border bg-bg px-4 py-3">
        <span class="h-2 w-2 rounded-full" style="background:var(--grad)" />
        <span class="text-[15px] font-medium text-ink">{item}</span>
      </div>
    ))
  }
</div>
