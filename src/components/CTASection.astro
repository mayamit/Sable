---
import Button from './Button.astro';

interface Props {
  headline: string;
  subhead?: string;
  cta: { label: string; href: string };
  tagline?: string;
}
const { headline, subhead, cta, tagline } = Astro.props;
---

<section class="px-5 py-20 sm:px-8 sm:py-28">
  <div
    class="relative mx-auto max-w-5xl overflow-hidden rounded-[calc(var(--radius-card)+8px)] px-8 py-16 text-center sm:px-16"
    style="background:var(--grad)"
  >
    <div
      class="pointer-events-none absolute inset-0 opacity-30"
      style="background: radial-gradient(30rem 20rem at 80% 0%, rgba(255,255,255,0.35), transparent 60%);"
      aria-hidden="true"
    >
    </div>
    <div class="relative">
      <h2 class="text-3xl font-bold text-white sm:text-4xl">{headline}</h2>
      {subhead && <p class="mx-auto mt-4 max-w-xl text-lg text-white/90">{subhead}</p>}
      <div class="mt-8 flex justify-center">
        <Button href={cta.href} variant="secondary" class="!bg-white !text-primary hover:!text-primary-700">
          {cta.label}
        </Button>
      </div>
      {
        tagline && (
          <p class="mt-8 text-sm font-medium uppercase tracking-wider text-white/80">{tagline}</p>
        )
      }
    </div>
  </div>
</section>
